{
  "manifest_version": 3,
  "name": "Lateness Estimator",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://calendar.google.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "css": ["src/styles.css"],
      "js": [
        "src/storage.js",
        "src/ui.js",
        "src/LabelModel.js",
        "src/observer.js",
        "src/contentScript.js"
      ]
    }
  ]
}